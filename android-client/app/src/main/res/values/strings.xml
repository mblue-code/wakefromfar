    <string name="legal_intro">This page summarizes privacy, billing, and open-source notices for WakeFromFar.</string>
    <string name="legal_section_privacy_title">Privacy notice</string>
    <string name="legal_section_privacy_body">For this app, the developer does not run a central cloud to store your wake and power-check activity.</string>
    <string name="legal_privacy_bullet_no_dev_storage">The developer does not save your app usage data on developer-operated servers.</string>
    <string name="legal_privacy_bullet_admin_backend">Wake actions and power-status checks are processed and stored by the backend operated by your administrator.</string>
    <string name="legal_privacy_bullet_local_storage">Your app stores session data locally on your device (for example backend address and auth token) using encrypted preferences.</string>
    <string name="legal_privacy_bullet_network_security">Use the service only over protected private networking (local WireGuard VPN or Tailscale, and optional admin-approved Cloudflare Tunnel).</string>
    <string name="legal_privacy_bullet_account_admin_only">Only your administrator can create your account and assign your username/password.</string>
    <string name="legal_privacy_bullet_no_sale">The developer does not sell personal data from this app.</string>
    <string name="legal_section_billing_title">Google Play Billing</string>
    <string name="legal_section_billing_body">Monetization features are planned to use Google Play Billing.</string>
    <string name="legal_billing_bullet_use_google_play">When purchases are enabled, the app will use Google Play Billing for subscriptions and in-app purchases.</string>
    <string name="legal_billing_bullet_google_handles_payment">Payment processing is handled by Google Play under Google terms; full payment card details are not processed by this app backend.</string>
    <string name="legal_billing_bullet_receipt_ids">The app/backend may process purchase receipts or transaction identifiers required for entitlement validation.</string>
    <string name="legal_billing_bullet_release_note">Billing compliance details will be finalized in release documentation when billing is shipped.</string>
    <string name="legal_section_oss_title">Open-source acknowledgments</string>
    <string name="legal_section_oss_body">Repo-tailored notices are maintained in THIRD_PARTY_NOTICES.md and summarized here.</string>
    <string name="legal_oss_bullet_python_direct">Python backend direct and development dependencies are listed with license and source links.</string>
    <string name="legal_oss_bullet_python_transitive">Notable Python transitive license notes are documented, including an MPL-2.0 component.</string>
    <string name="legal_oss_bullet_android_direct">Android direct dependencies and licenses are documented from the app Gradle manifest.</string>
    <string name="legal_oss_bullet_google_fonts">Google Fonts usage note is included for Outfit and JetBrains Mono.</string>
    <string name="legal_oss_bullet_container_os">Docker base image and Debian package compliance notes are included for redistribution scenarios.</string>
    <string name="legal_oss_bullet_play_billing_license">A planned Play Billing licensing note is included for future monetization releases.</string>
    <string name="legal_oss_bullet_review_date">Last reviewed: March 2, 2026.</string>
    <string name="legal_oss_disclaimer">Informational summary only. For distribution compliance, include exact upstream license texts for release artifacts.</string>
