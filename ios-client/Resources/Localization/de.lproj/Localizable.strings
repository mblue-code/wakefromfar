"legal_title" = "Rechtliches und Datenschutz";
"legal_overview_title" = "Überblick";
"legal_intro" = "WakeFromFar auf dem iPhone spricht direkt mit dem Backend, das dein Administrator betreibt. Diese App ergänzt keine vom WakeFromFar-Entwickler betriebene Cloud.";
"legal_privacy_title" = "Datenschutz";
"legal_privacy_item_backend" = "Anmeldung, Wake-Anfragen, Geräte-Statusprüfungen, Shutdown-Anfragen und Admin-Aktivitäten werden vom Backend verarbeitet, das dein Administrator auswählt.";
"legal_privacy_item_keychain" = "Das Sitzungstoken der Anmeldung wird in der iOS-Keychain gespeichert und bleibt auf diesem Gerät.";
"legal_privacy_item_defaults" = "Backend-URL, Benutzername-Hinweis, Sprache, Darstellung und Benachrichtigungskennungen werden lokal auf diesem iPhone gespeichert.";
"legal_privacy_item_notifications" = "Wenn Admin-Benachrichtigungen aktiviert sind, speichert die App eine lokale Installationskennung und das aktuelle APNs-Token und registriert beides beim ausgewählten Backend, damit es generische Admin-Hinweise senden kann.";
"legal_privacy_item_billing" = "Apple verarbeitet die Zahlung fuer die Verteilung ueber den App Store. Die normale iPhone-App-Nutzung fuehrt keine In-App-Kauf-, Pro-Unlock- oder Entitlement-Synchronisierungsschritte aus, bevor für dein Konto verfügbare Geräte angezeigt werden.";
"legal_privacy_item_network" = "Nutze die App nur über geschützte private Netzwerke, die dein Administrator freigegeben hat.";
"legal_compliance_title" = "Apple-Compliance-Leitplanken";
"legal_compliance_item_no_invites" = "Invite-Claim und Deep-Link-Onboarding sind auf dem iPhone absichtlich nicht implementiert.";
"legal_compliance_item_apns" = "Admin-Hinweise verwenden APNs mit generischen Inhalten und leiten in die Aktivität weiter, statt Gerätedetails im Hinweistext preiszugeben.";
"legal_compliance_item_permissions" = "Die Benachrichtigungsberechtigung wird nur für Admin-Hinweise angefragt, wenn ein Admin die Aktivität öffnet oder Benachrichtigungen in den Einstellungen verwaltet.";
"legal_compliance_item_background" = "Die App verwendet keine Android-ähnlichen Foreground-Services, kein periodisches Hintergrund-Polling und keine nicht unterstützte Hintergrundausführung.";
"legal_compliance_item_app_store_distribution" = "Die iPhone-App folgt einem kostenpflichtigen App-Store-Modell und praesentiert keinen normalen In-App-Kauf- oder Kaufverwaltungsfluss.";
"legal_open_source_title" = "Open Source";
"legal_open_source_item_repo" = "Repository-weite Dokumente zu Rechtlichem, Datenschutz, Support, Distribution und Marken bleiben die Quelle für die öffentliche Weitergabe.";
"legal_open_source_item_notices" = "THIRD_PARTY_NOTICES.md dokumentiert die Backend-, Android-, Container- und gemeinsamen Abhängigkeits-Hinweise für die Release-Compliance.";
"legal_open_source_item_ios_foundation" = "Das iPhone-Ziel in diesem Repository nutzt derzeit hauptsächlich Apple-System-Frameworks und keine eingecheckte Drittanbieter-Paket-Sperrliste.";
"legal_open_source_item_distribution" = "Offizielle Binaries sind die vom Maintainer veröffentlichten Store-Releases. Source-Builds und Forks dürfen den Code unter der Repo-Lizenz nutzen, sollen aber keine offizielle Zugehörigkeit behaupten.";

