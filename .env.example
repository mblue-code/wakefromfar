APP_SECRET=replace-with-a-random-long-secret
TOKEN_EXPIRES_SECONDS=28800
ADMIN_USER=admin
ADMIN_PASS=replace-with-strong-password
ENFORCE_IP_ALLOWLIST=true
IP_ALLOWLIST_CIDRS=100.64.0.0/10,fd7a:115c:a1e0::/48,127.0.0.1/32,::1/128
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
LOGIN_RATE_LIMIT_PER_MINUTE=5
ONBOARDING_RATE_LIMIT_PER_MINUTE=5
WAKE_RATE_LIMIT_PER_MINUTE=20
SHUTDOWN_POKE_REQUEST_RATE_LIMIT_PER_MINUTE=10
SHUTDOWN_POKE_SEEN_RATE_LIMIT_PER_MINUTE=30
SHUTDOWN_POKE_RESOLVE_RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
ENABLE_API_DOCS=false
WAKE_SEND_MAX_ATTEMPTS=2
WAKE_SEND_BACKOFF_MS=150
POWER_CHECK_TIMEOUT_SECONDS=1.5
POWER_STATE_STALE_SECONDS=20
DISCOVERY_ENABLED=true
DISCOVERY_RATE_LIMIT_PER_MINUTE=6
DISCOVERY_MAX_CONCURRENT_PROBES=64
DISCOVERY_DEFAULT_HOST_CAP=256
DISCOVERY_DEFAULT_TCP_PORTS=22,80,443,445
DISCOVERY_RUN_TIMEOUT_SECONDS=120
